# Bitget API — needs FUTURES Read + Futures Trade permissions
# Bitget > Profile > API Management > Create/Edit API Key
BITGET_API_KEY=your_api_key_here
BITGET_SECRET_KEY=your_secret_key_here
BITGET_PASSPHRASE=your_passphrase_here

# Telegram Bot (from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here  # Message @userinfobot to get this

# Groq AI (from console.groq.com — free)
GROQ_API_KEY=your_groq_key_here

# Trading Settings (optional overrides)
# LEVERAGE=10
# MARGIN_MODE=crossed
